<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js"></script>
<script>
  // Firebase Config
  const firebaseConfig = {
    apiKey: "AIzaSyATvwM_0B9ibtD9MniIoiNuiirnC0mb2AY",
    authDomain: "newtechhomesolutions-b6ab6.firebaseapp.com",
    projectId: "newtechhomesolutions-b6ab6",
    storageBucket: "newtechhomesolutions-b6ab6.firebasestorage.app",
    messagingSenderId: "1015056454392",
    appId: "1:1015056454392:web:2d764c7f4e0f769407e10d",
    measurementId: "G-8HV2QWDK4W"
  };

  firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();
  const auth = firebase.auth();

  // Mobile menu
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger.addEventListener('click',()=>{
    navLinks.classList.toggle('active');
  });
  document.querySelectorAll('.nav-links a').forEach(a=>{
    a.addEventListener('click',()=>navLinks.classList.remove('active'));
  });

  // Scroll animations
  const observer = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.classList.add('visible');
      }
    });
  },{threshold:0.1});
  document.querySelectorAll('.fade-up').forEach(el=>observer.observe(el));


  async function ensureFirebaseWriteAccess(){
    if (auth.currentUser) return auth.currentUser;
    try {
      const cred = await auth.signInAnonymously();
      return cred.user;
    } catch (err) {
      console.warn('Anonymous auth failed; trying public Firestore write:', err.message);
      return null;
    }
  }

  function withTimeout(promise, ms, label){
    let timeoutId;
    const timeout = new Promise((_, reject) => {
      timeoutId = setTimeout(() => reject(new Error(label + ' timed out. Please check Firebase rules/network.')), ms);
    });
    return Promise.race([promise, timeout]).finally(() => clearTimeout(timeoutId));
  }

  function escapeHtml(value){
    return String(value || '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
  }

  function escapeAttr(value){
    return escapeHtml(value).replace(/'/g, '&#39;');
  }

  // ── Sync Gallery from Admin Media Manager ──
  const staticGalleryCards = `
    <div class="gallery-card fade-up visible">
      <div class="gallery-card-media">
        <img src="assets/services/pleated-mesh.jpg" alt="Pleated Mesh" loading="lazy">
        <div class="media-type-badge">📷 Photo</div>
      </div>
      <div class="gallery-card-body">
        <div class="gallery-card-category">Pleated Mesh</div>
        <p class="gallery-card-title">Pleated Mesh Window Installation</p>
      </div>
    </div>
    <div class="gallery-card fade-up visible">
      <div class="gallery-card-media">
        <img src="assets/services/honeycomb.jpg" alt="Honey Comb Partition" loading="lazy">
        <div class="media-type-badge">📷 Photo</div>
      </div>
      <div class="gallery-card-body">
        <div class="gallery-card-category">Honey Comb</div>
        <p class="gallery-card-title">Honey Comb Partition Work</p>
      </div>
    </div>
    <div class="gallery-card fade-up visible">
      <div class="gallery-card-media">
        <img src="assets/services/invisible-grill.jpg" alt="Invisible Grill" loading="lazy">
        <div class="media-type-badge">📷 Photo</div>
      </div>
      <div class="gallery-card-body">
        <div class="gallery-card-category">Invisible Grill</div>
        <p class="gallery-card-title">Invisible Grill Balcony Safety</p>
      </div>
    </div>
    <div class="gallery-card fade-up visible">
      <div class="gallery-card-media">
        <img src="assets/services/bird-net.jpg" alt="Anti Bird Net" loading="lazy">
        <div class="media-type-badge">📷 Photo</div>
      </div>
      <div class="gallery-card-body">
        <div class="gallery-card-category">Anti Bird Net</div>
        <p class="gallery-card-title">Anti Bird Net Protection</p>
      </div>
    </div>`;

  let allMediaItems = [];
  let activeFilter = 'all';

  function renderGallery(items) {
    const grid = document.getElementById('galleryGrid');
    const filtered = activeFilter === 'all' ? items : items.filter(i => i.category === activeFilter);
    if (!filtered.length) {
      grid.innerHTML = '<div class="gallery-empty">✨ No projects yet in this category. Check back soon!</div>';
      return;
    }
    grid.innerHTML = filtered.map(item => {
      const title    = escapeHtml(item.title    || 'Project Installation');
      const category = escapeHtml(item.category || 'Our Work');
      const url      = escapeAttr(item.url);
      const isVideo  = item.type === 'video';
      return `
        <div class="gallery-card fade-up visible">
          <div class="gallery-card-media">
            ${isVideo
              ? `<video src="${url}" muted loop playsinline
                   onmouseover="this.play()" onmouseout="this.pause()"></video>
                 <div class="media-type-badge">🎬 Video</div>
                 <div class="play-btn-overlay"><div class="play-btn">&#9654;</div></div>`
              : `<img src="${url}" alt="${escapeAttr(title)}" loading="lazy">
                 <div class="media-type-badge">📷 Photo</div>`}
          </div>
          <div class="gallery-card-body">
            <div class="gallery-card-category">${category}</div>
            <p class="gallery-card-title">${title}</p>
          </div>
        </div>`;
    }).join('');
    document.querySelectorAll('.gallery-card.fade-up').forEach(el => observer.observe(el));
  }

  // Filter button handlers
  document.getElementById('galleryFilters').addEventListener('click', e => {
    if (!e.target.classList.contains('filter-btn')) return;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    activeFilter = e.target.dataset.filter;
    if (allMediaItems.length) renderGallery(allMediaItems);
  });

  db.collection('media')
    .orderBy('createdAt', 'desc')
    .onSnapshot(snap => {
      allMediaItems = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }))
        .filter(i => i.url && i.status === 'active');
      if (!allMediaItems.length) {
        document.getElementById('galleryGrid').innerHTML = staticGalleryCards;
        return;
      }
      renderGallery(allMediaItems);
    }, err => {
      console.warn('Gallery sync error:', err.message);
      document.getElementById('galleryGrid').innerHTML = staticGalleryCards;
    });

  // Sync Careers
  db.collection('jobs').where('status', '==', 'active').onSnapshot(snap => {
    const grid = document.getElementById('jobsContainer');
    if (snap.empty) return;
    grid.innerHTML = snap.docs.map(doc => {
      const job = doc.data();
      return `
        <div class="card fade-up visible" style="background: white; padding: 30px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 20px rgba(0,0,0,0.02);">
          <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:20px;">
            <div>
              <h3 style="margin-bottom:8px; color: #1e3a8a;">${escapeHtml(job.title)}</h3>
              <span style="background:#e0f2fe; color:#0369a1; padding:4px 12px; border-radius:999px; font-size:12px; font-weight:600;">${escapeHtml(job.department)}</span>
            </div>
            <button class="btn-primary" data-title="${escapeAttr(job.title)}" onclick="openJobForm(this.dataset.title)" style="padding: 10px 20px; font-size: 14px; border:none; cursor:pointer;">Apply</button>
          </div>
          <p style="color: #64748b; font-size: 14px; line-height: 1.6; margin-bottom: 20px;">${escapeHtml(job.description)}</p>
          <div style="font-size: 12px; color: #94a3b8; border-top: 1px solid #f1f5f9; padding-top: 15px;">Expires: ${escapeHtml(job.expiryDate)}</div>
        </div>
      `;
    }).join('');
  });

  window.openJobForm = function(title) {
    const portal = document.getElementById('appModalPortal');
    portal.innerHTML = `
      <div class="app-modal-overlay" id="appOverlay" onclick="if(event.target===this)closeAppModal()">
        <div class="app-modal-card" id="appModalCard">
          <div class="app-modal-header">
            <div class="app-job-badge">💼 Job Application</div>
            <h3>Apply for: ${escapeHtml(title)}</h3>
            <p>Fill out the form below and our team will get back to you shortly.</p>
            <button class="app-modal-close" onclick="closeAppModal()">✕</button>
          </div>
          <div class="app-modal-body">
            <form id="jobAppForm">
              <input type="hidden" id="jobTitleInput" value="${escapeHtml(title)}">

              <div class="app-section-label">👤 Personal Information</div>
              <div class="app-two-col">
                <div class="app-field">
                  <label>Full Name *</label>
                  <input type="text" id="appName" required placeholder="Your full name">
                </div>
                <div class="app-field">
                  <label>Phone Number *</label>
                  <input type="tel" id="appPhone" required placeholder="+91 XXXXX XXXXX">
                </div>
              </div>
              <div class="app-field">
                <label>Email Address *</label>
                <input type="email" id="appEmail" required placeholder="your@email.com">
              </div>

              <div class="app-section-label">📋 Your Application</div>
              <div class="app-field">
                <label>Experience & Why should we hire you? *</label>
                <textarea id="appResume" required placeholder="Briefly describe your relevant experience, skills, and why you'd be a great fit for this role..."></textarea>
              </div>

              <button type="submit" class="app-submit-btn" id="appSubmitBtn">
                🚀 Submit Application
              </button>
            </form>
          </div>
        </div>
      </div>`;

    document.body.style.overflow = 'hidden';

    document.getElementById('jobAppForm').onsubmit = async (e) => {
      e.preventDefault();
      const btn = document.getElementById('appSubmitBtn');
      btn.disabled = true; btn.innerHTML = '⏳ Submitting…';
      try {
        await ensureFirebaseWriteAccess();
        await withTimeout(db.collection('careers').add({
          name: document.getElementById('appName').value.trim(),
          phone: document.getElementById('appPhone').value.trim(),
          email: document.getElementById('appEmail').value.trim(),
          position: document.getElementById('jobTitleInput').value,
          status: 'new',
          message: document.getElementById('appResume').value.trim(),
          createdAt: new Date().toISOString()
        }), 12000, 'Application submission');
        // Show success screen
        document.getElementById('appModalCard').innerHTML = `
          <div class="app-modal-header" style="border-radius:24px 24px 0 0;">
            <button class="app-modal-close" onclick="closeAppModal()">✕</button>
          </div>
          <div class="app-success-screen">
            <div class="app-success-icon">✅</div>
            <h3>Application Submitted!</h3>
            <p>Thank you for applying to <strong>${escapeHtml(title)}</strong>.<br>
            Our team will review your application and contact you soon.</p>
            <button onclick="closeAppModal()" style="margin-top:24px;padding:12px 32px;background:#1e3a8a;color:#fff;border:none;border-radius:12px;font-weight:700;font-size:14px;cursor:pointer;">Close</button>
          </div>`;
      } catch (err) {
        btn.disabled = false; btn.innerHTML = '🚀 Submit Application';
        alert('Could not submit application. Please try again.');
      }
    };
  };

  window.closeAppModal = function() {
    const portal = document.getElementById('appModalPortal');
    portal.innerHTML = '';
    document.body.style.overflow = '';
  };

  // Submit Leads
  document.getElementById('contactForm').onsubmit = async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const original = btn.innerHTML;
    btn.disabled = true; btn.innerHTML = 'Sending...';

    try {
      await ensureFirebaseWriteAccess();
      const payload = {
        name: document.getElementById('leadName').value.trim(),
        phone: document.getElementById('leadPhone').value.trim(),
        email: document.getElementById('leadEmail').value.trim(),
        service: document.getElementById('leadService').value,
        message: document.getElementById('leadMessage').value.trim(),
        status: 'new',
        createdAt: new Date().toISOString()
      };
      await withTimeout(Promise.all([
        db.collection('quotes').add({ ...payload, location: '', source: 'website-get-quote' }),
        db.collection('leads').add({ ...payload, source: 'website-get-quote' })
      ]), 12000, 'Quote request');
      btn.innerHTML = '✓ Message Sent!';
      btn.style.background = '#10b981';
      e.target.reset();
      setTimeout(() => { btn.disabled = false; btn.innerHTML = original; btn.style.background = ''; }, 3000);
    } catch (err) {
      let msg = err.message;
      if(err.code === 'permission-denied') msg = 'Permission denied. Firebase rules may need to allow public writes to leads/quotes. Contact the admin.';
      else if(err.code === 'unavailable') msg = 'Network error. Please check your connection and try again.';
      alert('Message could not be sent: ' + msg);
      btn.disabled = false; btn.innerHTML = original;
    }
  };


  // ── Hero Slider ──────────────────────────────────────────────
  let _heroSlides = [];
  let _currentSlide = 0;
  let _sliderTimer = null;

  function initHeroSlider(slides) {
    if (!slides || !slides.length) return;
    _heroSlides = slides;
    const sliderEl = document.getElementById('heroSlider');
    const navEl    = document.getElementById('heroSliderNav');
    if (!sliderEl || !navEl) return;

    sliderEl.innerHTML = slides.map((s, i) => `
      <div class="hero-slide ${i === 0 ? 'active' : ''}" id="hSlide${i}">
        <img src="${s.url}" alt="${(s.title || 'Home Solution').replace(/"/g,'&quot;')}" loading="${i === 0 ? 'eager' : 'lazy'}">
      </div>`).join('') + `
      <div class="hero-arrows">
        <button class="hero-arrow-btn" onclick="heroArrow(-1)" aria-label="Previous">&#8592;</button>
        <button class="hero-arrow-btn" onclick="heroArrow(1)" aria-label="Next">&#8594;</button>
      </div>`;

    navEl.innerHTML = slides.map((_, i) => `
      <button class="hero-dot ${i === 0 ? 'active' : ''}" onclick="heroGoTo(${i})" aria-label="Slide ${i+1}"></button>`).join('');

    if (_sliderTimer) clearInterval(_sliderTimer);
    if (slides.length > 1) {
      _sliderTimer = setInterval(() => heroArrow(1), 4500);
    }
  }

  window.heroGoTo = function(idx) {
    _heroSlides.forEach((_, i) => {
      const el = document.getElementById('hSlide' + i);
      if (el) el.classList.toggle('active', i === idx);
    });
    document.querySelectorAll('#heroSliderNav .hero-dot').forEach((d, i) =>
      d.classList.toggle('active', i === idx));
    _currentSlide = idx;
  };

  window.heroArrow = function(dir) {
    if (!_heroSlides.length) return;
    heroGoTo((_currentSlide + dir + _heroSlides.length) % _heroSlides.length);
  };

  // ── Site Settings (thumbnails) listener ─────────────────────
  db.collection('siteSettings').doc('thumbnails').onSnapshot(doc => {
    if (!doc.exists) return;
    const data = doc.data();

    // Hero slider
    if (data.heroSlides && data.heroSlides.length) {
      const sorted = [...data.heroSlides].sort((a, b) => (a.order || 0) - (b.order || 0));
      initHeroSlider(sorted);
    }

    // Category images
    const catMap = {
      pleatedMesh:    'catImg-pleatedMesh',
      honeyComb:      'catImg-honeyComb',
      invisibleGrill: 'catImg-invisibleGrill',
      antiBirdNet:    'catImg-antiBirdNet'
    };
    if (data.categoryImages) {
      Object.entries(catMap).forEach(([key, elId]) => {
        if (data.categoryImages[key]?.url) {
          const el = document.getElementById(elId);
          if (el) el.src = data.categoryImages[key].url;
        }
      });
    }

    // About section image
    if (data.aboutImage?.url) {
      const el = document.getElementById('aboutImg');
      if (el) el.src = data.aboutImage.url;
    }
  }, err => console.warn('siteSettings error:', err.message));

  window.addEventListener('scroll',()=>{
    const nav = document.querySelector('.navbar');
    if(window.scrollY > 50){ nav.style.boxShadow = '0 4px 30px rgba(0,0,0,0.1)'; }
    else { nav.style.boxShadow = '0 2px 20px rgba(0,0,0,0.06)'; }
  });
</script>
</body>
</html>
