  DB.set('messages',DB.get('messages').filter(m=>m.id!==id));
  renderMessages();
  showToast('Message deleted','info');
}

// ============ SETTINGS ============
function saveSettings(){
  DB.set('settings',{
    name:document.getElementById('setSiteName').value,
    tagline:document.getElementById('setTagline').value,
    email:document.getElementById('setEmail').value,
    phone:document.getElementById('setPhone').value,
    address:document.getElementById('setAddress').value
  });
  showToast('Settings saved successfully!','success');
}

// ============ DASHBOARD ============
function refreshDashboard(){
  document.getElementById('statPhotos').textContent=DB.get('photos').length;
  document.getElementById('statVideos').textContent=DB.get('videos').length;
  document.getElementById('statBlogs').textContent=DB.get('blogs').length;
  document.getElementById('statProducts').textContent=DB.get('products').length;
  
  // Recent messages
  const msgs=DB.get('messages').slice(0,5);
  const tbody=document.querySelector('#recentMsgsTable tbody');
  tbody.innerHTML=msgs.length?msgs.map(m=>`
    <tr>
      <td><strong>${m.name}</strong></td>
      <td>${(m.message||'').substring(0,50)}...</td>
      <td>${m.date}</td>
      <td><span class="status-pill status-${m.status==='read'?'active':'pending'}">${m.status}</span></td>
    </tr>`).join(''):`<tr><td colspan="4" style="text-align:center;color:#9ca3af;padding:30px;">No messages yet</td></tr>`;
  
  document.getElementById('msgBadge').textContent=DB.get('messages').filter(m=>m.status!=='read').length;
}

