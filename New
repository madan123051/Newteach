function getYouTubeId(url){
  const m=url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
  return m?m[1]:null;
}
function getVimeoId(url){
  const m=url.match(/vimeo\.com\/(\d+)/);
  return m?m[1]:null;
}

function renderVideos(){
  const grid=document.getElementById('videosGrid');
  const videos=DB.get('videos');
  if(!videos.length){
    grid.innerHTML=`<div class="empty-state" style="grid-column:1/-1;"><i class="fa-solid fa-video"></i><h4>No videos yet</h4><p>Add your first video</p></div>`;
    return;
  }
  grid.innerHTML=videos.map(v=>{
    let player='';
    if(v.type==='youtube'){
      const yid=getYouTubeId(v.url);
      player=yid?`<iframe src="https://www.youtube.com/embed/${yid}" allowfullscreen></iframe>`:`<div class="video-play">Invalid URL</div>`;
    } else if(v.type==='vimeo'){
      const vid=getVimeoId(v.url);
      player=vid?`<iframe src="https://player.vimeo.com/video/${vid}" allowfullscreen></iframe>`:`<div class="video-play">Invalid URL</div>`;
    } else {
      player=`<video src="${v.url}" controls></video>`;
    }
    return `
      <div class="video-card">
        <div class="video-thumb">${player}</div>
        <div class="video-body">
          <h4>${v.title}</h4>
          <p style="font-size:13px;color:#6b7280;margin-bottom:10px;">${v.desc||''}</p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:11px;color:#9ca3af;">${new Date(v.date).toLocaleDateString()}</span>
            <button class="btn btn-danger btn-sm" onclick="deleteVideo(${v.id})"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>
      </div>`;
  }).join('');
}

